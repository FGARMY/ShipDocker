# ═══════════════════════════════════════════
# SMDrop — Environment Variables
# ═══════════════════════════════════════════

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SMDrop

# Database (PostgreSQL)
DATABASE_URL=postgresql://smdrop:smdrop_dev_2024@localhost:5432/smdrop

# Redis
REDIS_URL=redis://localhost:6379

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=smdrop_meili_dev_key

# JWT Auth
JWT_SECRET=your-jwt-secret-change-me-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# PayPal (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=orders@smdrop.com

# File Storage (S3/R2)
S3_BUCKET=smdrop-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Encryption
ENCRYPTION_KEY=32-byte-encryption-key-change-me!

# Admin defaults
ADMIN_EMAIL=admin@smdrop.com
ADMIN_PASSWORD=admin123456
