generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════
// STORE & AUTH
// ═══════════════════════════════════════════

model Store {
  id        String   @id @default(cuid())
  name      String
  domain    String   @unique
  currency  String   @default("INR")
  timezone  String   @default("Asia/Kolkata")
  logoUrl   String?
  faviconUrl String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  customers     Customer[]
  suppliers     Supplier[]
  products      Product[]
  collections   Collection[]
  orders        Order[]
  coupons       Coupon[]
  pages         Page[]
  blogPosts     BlogPost[]
  syncLogs      SyncLog[]
  pricingRules  PricingRule[]
  shippingZones ShippingZone[]
}

model User {
  id           String    @id @default(cuid())
  storeId      String
  email        String    @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole  @default(MANAGER)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  blogPosts BlogPost[]

  @@index([storeId])
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
  SUPPORT
}

model Customer {
  id           String    @id @default(cuid())
  storeId      String
  email        String
  passwordHash String
  firstName    String?
  lastName     String?
  phone        String?
  avatar       String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  addresses Address[]
  orders    Order[]

  @@unique([storeId, email])
  @@index([storeId])
}

model Address {
  id         String  @id @default(cuid())
  customerId String
  label      String? @default("Home")
  firstName  String
  lastName   String
  line1      String
  line2      String?
  city       String
  state      String
  country    String  @default("IN")
  zip        String
  phone      String?
  isDefault  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
}

// ═══════════════════════════════════════════
// CATALOG
// ═══════════════════════════════════════════

model Product {
  id          String        @id @default(cuid())
  storeId     String
  title       String
  slug        String
  description String?       @db.Text
  status      ProductStatus @default(DRAFT)
  images      Json          @default("[]")
  tags        String[]      @default([])
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  store    Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants ProductVariant[]
  collections CollectionProduct[]
  reviews  Review[]

  @@unique([storeId, slug])
  @@index([storeId, status])
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model ProductVariant {
  id           String  @id @default(cuid())
  productId    String
  supplierId   String?
  supplierSku  String?
  sku          String
  title        String  @default("Default")
  costPrice    Float   @default(0)
  sellPrice    Float
  comparePrice Float?
  stock        Int     @default(0)
  weight       Float?
  options      Json    @default("{}")
  images       Json    @default("[]")
  position     Int     @default(0)

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
  orderItems OrderItem[]

  @@index([productId])
  @@index([supplierId])
  @@index([sku])
}

model Collection {
  id          String  @id @default(cuid())
  storeId     String
  title       String
  slug        String
  description String? @db.Text
  imageUrl    String?
  seoTitle    String?
  seoDesc     String?
  position    Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store    Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products CollectionProduct[]

  @@unique([storeId, slug])
  @@index([storeId])
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  author    String
  email     String?
  rating    Int
  title     String?
  body      String?  @db.Text
  isApproved Boolean @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ═══════════════════════════════════════════
// SUPPLIERS
// ═══════════════════════════════════════════

model Supplier {
  id          String       @id @default(cuid())
  storeId     String
  name        String
  type        SupplierType
  credentials Json         @default("{}")
  baseUrl     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  store          Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variants       ProductVariant[]
  supplierOrders SupplierOrder[]
  syncLogs       SyncLog[]

  @@index([storeId])
}

enum SupplierType {
  ALIEXPRESS
  CJ_DROPSHIPPING
  SPOCKET
  PRINTFUL
  PRINTIFY
  CSV_IMPORT
  CUSTOM
}

// ═══════════════════════════════════════════
// ORDERS & FULFILLMENT
// ═══════════════════════════════════════════

model Order {
  id              String        @id @default(cuid())
  storeId         String
  customerId      String?
  shippingAddress String?
  addressId       String?
  customerEmail   String
  customerName    String
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String?
  paymentId       String?
  subtotal        Float
  shippingCost    Float         @default(0)
  discount        Float         @default(0)
  tax             Float         @default(0)
  total           Float
  couponCode      String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id])
  address        Address?        @relation(fields: [addressId], references: [id])
  items          OrderItem[]
  supplierOrders SupplierOrder[]
  fulfillments   Fulfillment[]

  @@index([storeId, status])
  @@index([customerId])
  @@index([paymentId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Float
  costPrice Float  @default(0)
  total     Float

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

model SupplierOrder {
  id             String              @id @default(cuid())
  orderId        String
  supplierId     String
  externalId     String?
  status         SupplierOrderStatus @default(PENDING)
  trackingNumber String?
  carrier        String?
  cost           Float               @default(0)
  placedAt       DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  errorMessage   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([orderId])
  @@index([supplierId])
}

enum SupplierOrderStatus {
  PENDING
  PLACED
  CONFIRMED
  SHIPPED
  DELIVERED
  FAILED
  CANCELLED
}

model Fulfillment {
  id             String    @id @default(cuid())
  orderId        String
  trackingNumber String?
  carrier        String?
  trackingUrl    String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ═══════════════════════════════════════════
// COMMERCE
// ═══════════════════════════════════════════

model Coupon {
  id         String     @id @default(cuid())
  storeId    String
  code       String
  type       CouponType
  value      Float
  minOrder   Float?
  usageLimit Int?
  usedCount  Int        @default(0)
  isActive   Boolean    @default(true)
  expiresAt  DateTime?
  createdAt  DateTime   @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
  @@index([storeId])
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

model PricingRule {
  id          String          @id @default(cuid())
  storeId     String
  name        String
  scope       PricingScope    @default(GLOBAL)
  scopeId     String?
  markupType  MarkupType      @default(MULTIPLIER)
  markupValue Float           @default(2)
  roundTo     Float?          @default(0.99)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

enum PricingScope {
  GLOBAL
  CATEGORY
  SUPPLIER
  PRODUCT
}

enum MarkupType {
  MULTIPLIER
  FIXED_AMOUNT
  PERCENTAGE
}

model ShippingZone {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  countries Json     @default("[]")
  createdAt DateTime @default(now())

  store Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rates ShippingRate[]

  @@index([storeId])
}

model ShippingRate {
  id        String       @id @default(cuid())
  zoneId    String
  name      String
  type      ShippingType @default(FLAT)
  price     Float        @default(0)
  minWeight Float?
  maxWeight Float?
  minOrder  Float?
  freeAbove Float?

  zone ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
}

enum ShippingType {
  FLAT
  WEIGHT_BASED
  FREE
}

// ═══════════════════════════════════════════
// CONTENT
// ═══════════════════════════════════════════

model Page {
  id          String    @id @default(cuid())
  storeId     String
  title       String
  slug        String
  content     String    @db.Text
  seoTitle    String?
  seoDesc     String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@index([storeId])
}

model BlogPost {
  id          String    @id @default(cuid())
  storeId     String
  authorId    String
  title       String
  slug        String
  excerpt     String?
  content     String    @db.Text
  imageUrl    String?
  tags        String[]  @default([])
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store  Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@unique([storeId, slug])
  @@index([storeId])
}

// ═══════════════════════════════════════════
// SYSTEM
// ═══════════════════════════════════════════

model SyncLog {
  id             String     @id @default(cuid())
  storeId        String
  supplierId     String?
  type           SyncType
  status         SyncStatus @default(RUNNING)
  itemsProcessed Int        @default(0)
  errorMessage   String?
  startedAt      DateTime   @default(now())
  completedAt    DateTime?

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([storeId])
}

enum SyncType {
  INVENTORY
  PRICE
  PRODUCT_IMPORT
  ORDER_STATUS
  FULL_SYNC
}

enum SyncStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}
